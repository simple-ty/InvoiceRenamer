{
  "date": [
    {
      "pattern": "开票日期\\s*[：:]?\\s*(\\d{4})\\s*年\\s*(\\d{1,2})\\s*月\\s*(\\d{1,2})\\s*日",
      "format": "y.m.d"
    },
    {
      "pattern": "国家税务总局\\s*(\\d{4})\\s*年\\s*(\\d{1,2})\\s*月\\s*(\\d{1,2})\\s*日",
      "format": "y.m.d"
    },
    {
      "pattern": "(\\d{4})\\s*年\\s*(\\d{1,2})\\s*月\\s*(\\d{1,2})\\s*日",
      "format": "y.m.d"
    },
    {
      "pattern": "国家税务总局[\\s\\S]{0,20}?(\\d{4})\\s+(\\d{2})\\s+(\\d{2})",
      "format": "y.m.d"
    }
  ],
  "number": [
